{
  "manifest_version": 3,
  "name": "VerdictFX",
  "version": "1.1",
  "description": "Plays success video and failure sound for LeetCode & GFG submissions.",
  "permissions": ["activeTab", "scripting"],
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/*",
        "https://practice.geeksforgeeks.org/*",
        "https://www.geeksforgeeks.org/problems/*",
        "https://geeksforgeeks.org/problems/*"
      ],
      "js": ["content.js"],
      "css": ["inject.css"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["success.mp4", "failure.mp3"],
      "matches": ["<all_urls>"]
    }
  ]
}